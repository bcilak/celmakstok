# Flask Ayarları
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-secret-key

# Veritabanı Ayarları
DATABASE_URL=postgresql://celmak_user:your-password@localhost:5432/celmak_stok
DB_PASSWORD=your-secure-password-here

# Docker için (docker-compose kullanırken)
# DATABASE_URL=postgresql://celmak_user:your-password@db:5432/celmak_stok

# Uygulama Ayarları
DEBUG=False
TESTING=False

# Session Ayarları
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=3600

# Upload Ayarları
MAX_CONTENT_LENGTH=104857600  # 100MB
UPLOAD_FOLDER=app/static/uploads

# Güvenlik
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=None

# API Güvenliği (Opsiyonel)
# Dış uygulamalar için API Key - boş bırakılırsa sadece login_required kontrolü yapılır
# API_KEY=sk_live_1234567890abcdef

# Base URL
BASE_URL=http://localhost:5000

# Gemini AI API Anahtarı
GEMINI_API_KEY=your-gemini-api-key-here

# Pazar Araştırması — Web Arama (ikisinden biri yeterli)
# Seçenek 1: Google Custom Search Engine (ücretsiz 100 sorgu/gün)
#   Adım 1: https://programmablesearchengine.google.com/  → yeni arama motoru oluştur → ID'yi kopyala
#   Adım 2: https://console.cloud.google.com/  → "Custom Search JSON API" etkinleştir → API key al
# GOOGLE_CSE_KEY=your-google-api-key
# GOOGLE_CSE_ID=your-custom-search-engine-id
#
# Seçenek 2: SerpAPI (alışveriş/fiyat sonuçları daha iyi)
#   → https://serpapi.com/  adresinden ücretsiz hesap aç (100 arama/ay)
# SERPAPI_KEY=your-serpapi-key
